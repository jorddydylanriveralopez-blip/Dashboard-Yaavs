# Opcional: sincronización en equipo (gerente ↔ empleados en distintos dispositivos)
VITE_API_URL=http://localhost:3001

# Obligatoria en Hostinger / Render / Fly (misma Neon que usaba Vercel).
# Sin esto el tablero arranca vacío y no verás los proyectos existentes.
# DATABASE_URL=postgresql://neondb_owner:....@....neon.tech/neondb?sslmode=require

# Google Analytics 4 (servidor / Vercel — no en el frontend)
# GA4_PROPERTY_ID=123456789
# GA4_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# Meta Ads (Marketing API — panel Redes / community)
# Ad Account sin prefijo act_. Token de System User con permiso ads_read.
# META_AD_ACCOUNT_ID=767897578413309
# META_ACCESS_TOKEN=EAAB...
# META_API_VERSION=v21.0

# Opcional: asistente Yaavs Bot con IA (OpenAI u API compatible)
# Sin estas variables el bot usa modo guía local (proyectos, retrasos, indicaciones).
# VITE_AI_API_KEY=sk-...
# VITE_AI_API_URL=https://api.openai.com/v1/chat/completions
# VITE_AI_MODEL=gpt-4o-mini

# Recordatorios de agenda por correo (Orlando y otros usuarios configurados)
# RESEND_API_KEY=re_...
# RESEND_FROM=Yaavs Agenda <agenda@yaavs.com.mx>
# BLOB_READ_WRITE_TOKEN=vercel_blob_...
# CRON_SECRET=un-secreto-largo-para-el-cron

# WhatsApp de gerentes (ausencias): si faltan en Contactos del tablero
# VITE_ORLANDO_WHATSAPP=521XXXXXXXXXX
# VITE_JC_WHATSAPP=521XXXXXXXXXX
