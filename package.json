{
  "name": "empresa-board",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/print-mobile-url.mjs && vite --host",
    "dev:server": "node server/index.mjs",
    "dev:all": "concurrently -n web,api -c cyan,magenta \"npm run dev\" \"npm run dev:server\"",
    "build": "tsc -b && vite build",
    "start": "node server/index.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "seed:server": "node server/seed-init.mjs"
  },
  "dependencies": {
    "@google-analytics/data": "^6.1.0",
    "@neondatabase/serverless": "^1.1.0",
    "@supabase/supabase-js": "^2.110.8",
    "@vercel/blob": "^2.6.1",
    "cors": "^2.8.5",
    "dictionary-es": "^4.0.0",
    "express": "^5.1.0",
    "nspell": "^2.1.5",
    "pg": "^8.22.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/nspell": "^2.1.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0"
  }
